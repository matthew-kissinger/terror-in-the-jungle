{
  "name": "terror-in-the-jungle",
  "private": true,
  "version": "0.0.0",
  "knip": {
    "tags": [
      "-lintignore"
    ]
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "npx tsx scripts/prebake-navmesh.ts",
    "build": "tsc && vite build",
    "navmesh:generate": "npx tsx scripts/prebake-navmesh.ts --force",
    "preview": "vite preview",
    "smoke:prod": "npx tsx scripts/prod-smoke.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "perf:baseline": "npx tsx scripts/perf-baseline.ts",
    "perf:capture": "npx tsx scripts/perf-capture.ts --headed",
    "perf:capture:headless": "npx tsx scripts/perf-capture.ts",
    "perf:capture:headed": "npx tsx scripts/perf-capture.ts --headed",
    "perf:capture:devtools": "npx tsx scripts/perf-capture.ts --headed --devtools",
    "perf:capture:combat120": "npx tsx scripts/perf-capture.ts --headed --mode ai_sandbox --npcs 120 --duration 90 --warmup 15",
    "perf:capture:zonecontrol": "npx tsx scripts/perf-capture.ts --headed --mode zone_control --npcs 60 --duration 120 --warmup 15 --runtime-preflight false",
    "perf:capture:teamdeathmatch": "npx tsx scripts/perf-capture.ts --headed --mode team_deathmatch --npcs 80 --duration 120 --warmup 15 --runtime-preflight false",
    "perf:capture:openfrontier:short": "npx tsx scripts/perf-capture.ts --headed --mode open_frontier --npcs 120 --duration 180 --warmup 20 --sample-interval-ms 1500 --detail-every-samples 2 --runtime-preflight false",
    "perf:capture:ashau:short": "npx tsx scripts/perf-capture.ts --headed --mode a_shau_valley --npcs 60 --duration 180 --warmup 20 --sample-interval-ms 1500 --detail-every-samples 2 --runtime-preflight false",
    "perf:capture:combat120:losprefilter": "npx tsx scripts/perf-capture.ts --headed --mode ai_sandbox --npcs 120 --duration 90 --warmup 15 --los-height-prefilter true",
    "perf:capture:frontier30m": "npx tsx scripts/perf-capture.ts --headed --mode open_frontier --npcs 120 --duration 1800 --warmup 30 --sample-interval-ms 2000 --detail-every-samples 5 --runtime-preflight false",
    "perf:analyze:latest": "npx tsx scripts/perf-analyze-latest.ts",
    "perf:terrain-probe": "npx tsx scripts/terrain-stream-probe.ts",
    "perf:terrain-probe:ashau": "npx tsx scripts/terrain-stream-probe.ts --mode a_shau_valley",
    "perf:terrain-probe:ashau:traverse": "npx tsx scripts/terrain-stream-probe.ts --mode a_shau_valley --samples 10 --interval-ms 750 --settle-ms 2000 --move-step 160",
    "perf:terrain-probe:frontier:traverse": "npx tsx scripts/terrain-stream-probe.ts --mode open_frontier --samples 10 --interval-ms 750 --settle-ms 2000 --move-step 160",
    "assets:optimize": "npx tsx scripts/optimize-assets.ts",
    "assets:optimize:vegetation": "npx tsx scripts/optimize-assets.ts --category vegetation --force",
    "assets:optimize:dry": "npx tsx scripts/optimize-assets.ts --dry-run",
    "assets:fix-alpha": "npx tsx scripts/fix-vegetation-alpha.ts",
    "ui:matrix": "npx tsx scripts/ui-device-matrix.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:integration": "vitest run src/integration/",
    "test:frontier": "vitest run src/systems/terrain/TerrainRenderRuntime.test.ts src/systems/terrain/TerrainSystem.test.ts src/systems/player/PlayerMovement.test.ts src/systems/helicopter/HelipadSystem.test.ts src/systems/helicopter/HelicopterModel.test.ts src/integration/scenarios/combat-flow.test.ts src/integration/scenarios/zone-capture.test.ts",
    "test:quick": "vitest run --reporter=dot",
    "deadcode": "knip",
    "perf:quick": "npx tsx scripts/perf-capture.ts --headed --duration 30 --warmup 8 --npcs 60",
    "perf:compare": "npx tsx scripts/perf-compare.ts",
    "perf:update-baseline": "npx tsx scripts/perf-compare.ts --update-baseline",
    "validate": "npm run lint && npm run test:run && npm run build && npm run smoke:prod",
    "validate:full": "npm run test:run && npm run build && npm run perf:capture:combat120 && npm run perf:compare -- --scenario combat120",
    "probe": "npx tsx scripts/engine-health-probe.ts",
    "probe:all": "npx tsx scripts/engine-health-probe.ts --all-modes",
    "check:hud": "npx tsx scripts/hud-layout-validator.ts",
    "check:memory": "npx tsx scripts/memory-growth-tracker.ts",
    "check:assets": "npx tsx scripts/asset-load-analyzer.ts",
    "check:states": "npx tsx scripts/state-coverage-probe.ts",
    "profile:modes": "npx tsx scripts/mode-load-profiler.ts"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/three": "^0.183.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "jsdom": "^29.0.0",
    "knip": "^5.63.1",
    "playwright": "^1.58.2",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^4.0.18",
    "webgl-memory": "^1.1.3"
  },
  "overrides": {
    "flatted": "^3.4.2"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource/rajdhani": "^5.2.7",
    "@fontsource/teko": "^5.2.7",
    "@preact/signals-core": "^1.13.0",
    "@recast-navigation/core": "^0.43.0",
    "@recast-navigation/three": "^0.43.0",
    "three": "^0.183.0",
    "three-mesh-bvh": "^0.9.8"
  }
}
