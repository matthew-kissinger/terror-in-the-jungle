{
  "name": "terror-in-the-jungle",
  "description": "Browser-based combined-arms Vietnam-theater FPS/RTS sandbox built on Three.js + WebGPU/TSL — infantry, ground vehicles, helicopters (UH-1 Huey, AH-1 Cobra), and fixed-wing aircraft (A-1 Skyraider, F-4 Phantom, AC-47 Spooky) in a single runtime, with materialization-tiered combat architected for ~3,000 NPCs.",
  "keywords": [
    "threejs",
    "webgpu",
    "tsl",
    "vietnam",
    "fps",
    "rts",
    "combined-arms",
    "aviation",
    "helicopters",
    "fixed-wing",
    "vehicles",
    "browser-game",
    "real-terrain",
    "recast-navigation"
  ],
  "homepage": "https://terror-in-the-jungle.pages.dev/",
  "repository": {
    "type": "git",
    "url": "https://github.com/matthew-kissinger/terror-in-the-jungle.git"
  },
  "license": "AGPL-3.0-or-later",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*"
  ],
  "knip": {
    "entry": [
      "public/sw.js",
      "scripts/**/*.{test,spec}.ts",
      "scripts/hud-state-probe.ts",
      "scripts/ecs-spike-bench.ts",
      "scripts/perf-active-driver.cjs",
      "scripts/perf-browser-observers.js",
      "scripts/probe-alpha-protection.ts",
      "scripts/probe-altitude-hold-clamp.ts",
      "scripts/probe-climb-oscillation.ts",
      "scripts/probe-ground-rolling.ts"
    ],
    "ignoreDependencies": [
      "@cloudflare/workers-types",
      "wrangler",
      "@gltf-transform/core",
      "@gltf-transform/extensions"
    ],
    "ignoreFiles": [
      ".claude/skills/**",
      "public/mockups/**"
    ],
    "ignore": [
      "scripts/capture-*-shots.ts",
      "tools/generate-*.mjs",
      "scripts/audit-archive/**",
      "scripts/capture-terrain-foundation-proof.ts",
      "scripts/check-land-vehicle-runtime.ts",
      "scripts/mobile-renderer-probe.ts",
      "scripts/perf-startup-mobile.ts",
      "scripts/perf-tsl-shader-cost.ts",
      "scripts/real-device-validation.ts",
      "scripts/bake-vegetation-impostor.mjs",
      "scripts/bake-veg-card.mjs",
      "scripts/bake-topo-dem.ts",
      "scripts/stage-kiln-war-export.mjs",
      "tools/kiln-asset-batch/build-packs.mjs",
      "tools/weapon/capture-ads-align.mjs",
      "src/systems/assets/PixelForgePropCatalog.ts",
      "src/systems/combat/weapons/NpcM2HBAdapter.ts"
    ],
    "tags": [
      "-lintignore"
    ]
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "npx tsx scripts/prebake-navmesh.ts",
    "build": "tsc && vite build && npx tsx scripts/compress-data-assets.ts && npm run cloudflare:assets:manifest",
    "build:perf": "cross-env VITE_PERF_HARNESS=1 tsc && cross-env VITE_PERF_HARNESS=1 vite build --outDir dist-perf && npm run cloudflare:assets:manifest -- --out=dist-perf/asset-manifest.json",
    "typecheck": "tsc --noEmit",
    "typecheck:scripts": "tsc -p tsconfig.scripts.json --noEmit",
    "doctor": "npx tsx scripts/doctor.ts",
    "validate:fast": "npm run check:pixel-forge-cutover && npm run check:pixel-forge-npc-crops && npm run typecheck && npm run lint && npm run lint:budget && npm run lint:docs && npm run check:doc-drift && npm run test:quick",
    "navmesh:generate": "npx tsx scripts/prebake-navmesh.ts --force",
    "preview": "vite preview",
    "preview:perf": "vite preview --outDir dist-perf",
    "smoke:prod": "npx tsx scripts/prod-smoke.ts",
    "ci:manual": "npx tsx scripts/github-workflow-run.ts ci.yml --ref master --watch",
    "deploy:prod": "npx tsx scripts/github-workflow-run.ts deploy.yml --ref master --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "lint:scripts": "eslint scripts/",
    "lint:scripts:fix": "eslint scripts/ --fix",
    "lint:budget": "npx tsx scripts/lint-source-budget.ts",
    "lint:docs": "npx tsx scripts/lint-docs.ts",
    "check:fence": "npx tsx scripts/check-fence.ts",
    "check:cycle": "npx tsx scripts/cycle-validate.ts",
    "check:smoke-scenarios": "npx tsx scripts/scenario-smoke.ts",
    "check:smoke-scenarios:dev": "npx tsx scripts/scenario-smoke.ts --server-mode dev",
    "artifact:prune": "npx tsx scripts/artifact-prune.ts",
    "artifact:prune:apply": "npx tsx scripts/artifact-prune.ts --apply",
    "perf:baseline": "npx tsx scripts/perf-baseline.ts",
    "perf:capture": "npx tsx scripts/perf-capture.ts --headed",
    "perf:capture:headless": "npx tsx scripts/perf-capture.ts",
    "perf:capture:headed": "npx tsx scripts/perf-capture.ts --headed",
    "perf:capture:devtools": "npx tsx scripts/perf-capture.ts --headed --devtools",
    "perf:capture:combat120": "npx tsx scripts/perf-capture.ts --headed --mode ai_sandbox --npcs 120 --duration 90 --warmup 15 --seed 2718",
    "perf:capture:zonecontrol": "npx tsx scripts/perf-capture.ts --headed --mode zone_control --npcs 60 --duration 120 --warmup 15 --runtime-preflight false",
    "perf:capture:teamdeathmatch": "npx tsx scripts/perf-capture.ts --headed --mode team_deathmatch --npcs 80 --duration 120 --warmup 15 --runtime-preflight false",
    "perf:capture:openfrontier:short": "npx tsx scripts/perf-capture.ts --headed --mode open_frontier --npcs 120 --duration 180 --warmup 20 --sample-interval-ms 1500 --detail-every-samples 2 --runtime-preflight false",
    "perf:capture:ashau:short": "npx tsx scripts/perf-capture.ts --headed --mode a_shau_valley --npcs 60 --duration 180 --warmup 20 --sample-interval-ms 1500 --detail-every-samples 2 --runtime-preflight false",
    "perf:capture:openfrontier:ears": "npx tsx scripts/perf-capture.ts --headed --renderer webgpu-strict --mode open_frontier --npcs 120 --duration 180 --warmup 20 --pressure-ready-warmup true --pressure-ready-timeout 120 --sample-interval-ms 1500 --detail-every-samples 2 --runtime-preflight false --runtime-render-submission-attribution true --runtime-render-submission-mode summary --compress-frontline false",
    "perf:capture:ashau:ears": "npx tsx scripts/perf-capture.ts --headed --renderer webgpu-strict --mode a_shau_valley --npcs 60 --duration 180 --warmup 20 --pressure-ready-warmup true --pressure-ready-timeout 120 --sample-interval-ms 1500 --detail-every-samples 2 --runtime-preflight false --runtime-render-submission-attribution true --runtime-render-submission-mode summary --compress-frontline false",
    "perf:startup:openfrontier": "npm run build && npx tsx scripts/perf-startup-ui.ts --mode open_frontier",
    "perf:grenade-spike": "npx tsx scripts/perf-grenade-spike.ts --headed --force-build",
    "perf:capture:combat120:losprefilter": "npx tsx scripts/perf-capture.ts --headed --mode ai_sandbox --npcs 120 --duration 90 --warmup 15 --seed 2718 --los-height-prefilter true",
    "perf:capture:frontier30m": "npx tsx scripts/perf-capture.ts --headed --mode open_frontier --npcs 120 --duration 1800 --warmup 30 --sample-interval-ms 2000 --detail-every-samples 5 --runtime-preflight false --match-duration 3600 --disable-victory true",
    "perf:analyze:latest": "npx tsx scripts/perf-analyze-latest.ts",
    "perf:terrain-probe": "npx tsx scripts/terrain-stream-probe.ts",
    "perf:terrain-probe:ashau": "npx tsx scripts/terrain-stream-probe.ts --mode a_shau_valley",
    "perf:terrain-probe:ashau:traverse": "npx tsx scripts/terrain-stream-probe.ts --mode a_shau_valley --samples 10 --interval-ms 750 --settle-ms 2000 --move-step 160",
    "perf:terrain-probe:frontier:traverse": "npx tsx scripts/terrain-stream-probe.ts --mode open_frontier --samples 10 --interval-ms 750 --settle-ms 2000 --move-step 160",
    "assets:optimize": "npx tsx scripts/optimize-assets.ts",
    "assets:optimize:vegetation": "npm run check:pixel-forge-cutover",
    "assets:optimize:dry": "npx tsx scripts/optimize-assets.ts --dry-run",
    "assets:fix-alpha": "npm run check:pixel-forge-cutover",
    "assets:import-pixel-forge-aircraft": "npx tsx scripts/import-pixel-forge-aircraft.ts",
    "assets:import-war-catalog": "npx tsx scripts/import-war-catalog.ts",
    "assets:scale-fix": "npx tsx scripts/apply-catalog-scale-fix.ts",
    "assets:bake-static-impostors": "npx tsx scripts/bake-static-impostor-atlases.ts",
    "assets:bleed-vegetation-atlases": "npx tsx scripts/bleed-vegetation-atlas-alpha.ts",
    "assets:generate-npc-crops": "npx tsx scripts/generate-pixel-forge-npc-tile-crops.ts",
    "ui:matrix": "npx tsx scripts/ui-device-matrix.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:integration": "vitest run src/integration/",
    "test:frontier": "vitest run src/systems/terrain/TerrainRenderRuntime.test.ts src/systems/terrain/TerrainSystem.test.ts src/systems/player/PlayerMovement.test.ts src/systems/helicopter/HelipadSystem.test.ts src/systems/helicopter/HelicopterModel.test.ts src/integration/scenarios/combat-flow.test.ts src/integration/scenarios/zone-capture.test.ts",
    "test:determinism": "vitest run src/core/SeededRandom.test.ts src/core/ReplayRecorder.test.ts src/core/ReplayPlayer.test.ts",
    "test:quick": "vitest run --reporter=dot",
    "deadcode": "knip",
    "knip:ci": "knip --include files,dependencies,unlisted,binaries,unresolved --no-config-hints",
    "perf:quick": "npx tsx scripts/perf-capture.ts --headed --duration 30 --warmup 8 --npcs 60",
    "perf:compare": "npx tsx scripts/perf-compare.ts",
    "perf:compare:strict": "npx tsx scripts/perf-compare.ts --fail-on-warn",
    "perf:update-baseline": "npx tsx scripts/perf-compare.ts --update-baseline",
    "validate": "npm run lint && npm run test:run && npm run build && npm run smoke:prod",
    "validate:full": "npm run test:run && npm run build && npm run perf:capture:combat120 && npm run perf:compare -- --scenario combat120",
    "probe": "npx tsx scripts/engine-health-probe.ts",
    "probe:pixel-forge-npcs": "npx tsx scripts/probe-pixel-forge-npcs.ts",
    "probe:all": "npx tsx scripts/engine-health-probe.ts --all-modes",
    "probe:fixed-wing": "npx tsx scripts/fixed-wing-runtime-probe.ts",
    "check:hud": "npx tsx scripts/hud-layout-validator.ts",
    "check:mobile-ui": "npx tsx scripts/mobile-ui-check.ts",
    "check:memory": "npx tsx scripts/memory-growth-tracker.ts",
    "check:assets": "npx tsx scripts/asset-load-analyzer.ts",
    "check:pixel-forge-cutover": "npx tsx scripts/validate-pixel-forge-cutover.ts",
    "check:pixel-forge-npc-crops": "npx tsx scripts/generate-pixel-forge-npc-tile-crops.ts --check",
    "check:pixel-forge-textures": "npx tsx scripts/pixel-forge-texture-audit.ts",
    "check:war-asset-payloads": "npx tsx scripts/war-asset-payload-audit.ts",
    "check:pixel-forge-optics": "npx tsx scripts/pixel-forge-imposter-optics-audit.ts",
    "check:vegetation-grounding": "npx tsx scripts/vegetation-grounding-audit.ts",
    "check:vegetation-horizon": "npx tsx scripts/vegetation-horizon-audit.ts",
    "check:vietnam-species-source-specs": "npx tsx scripts/check-vietnam-species-source-specs.ts",
    "check:terrain-hydrology-debug-proof": "npx tsx scripts/check-terrain-hydrology-debug-proof.ts",
    "check:visual-forest-world-systems-proof": "npx tsx scripts/check-visual-forest-world-systems-proof.ts",
    "check:world-systems-profile": "npx tsx scripts/check-world-systems-profile.ts",
    "check:world-systems-proof": "npx tsx scripts/check-world-systems-proof.ts",
    "check:world-systems-release-readiness": "npx tsx scripts/check-world-systems-release-readiness.ts",
    "check:webgpu-strategy": "npx tsx scripts/webgpu-strategy-audit.ts",
    "check:renderer-matrix": "npx tsx scripts/renderer-matrix.ts",
    "check:scene-parity": "npx tsx scripts/scene-parity-probe.ts --renderer webgpu-strict --headed",
    "check:asset-material": "npx tsx scripts/check-asset-material.ts",
    "check:asset-crops": "npx tsx scripts/asset-crop-probe.ts --renderer webgpu-strict --headed",
    "check:asset-gallery": "npx tsx scripts/check-asset-gallery.ts",
    "check:vegetation-lod-review": "npx tsx scripts/check-vegetation-lod-review.ts",
    "check:static-impostors": "npx tsx scripts/check-static-impostors.ts",
    "check:vegetation-adapter": "npx tsx scripts/check-vegetation-adapter.ts",
    "check:terrain-fire-authority": "npx tsx scripts/terrain-fire-authority-probe.ts --renderer webgpu-strict --headed",
    "check:doc-drift": "npx tsx scripts/doc-drift.ts",
    "check:doc-drift:full": "npx tsx scripts/doc-drift.ts --full",
    "check:cycle-close": "npx tsx scripts/check-cycle-close.ts",
    "check:live-release": "npx tsx scripts/check-live-release.ts",
    "check:culling-baseline": "npx tsx scripts/check-culling-baseline.ts",
    "check:culling-proof": "npx tsx scripts/check-culling-proof.ts --headed",
    "check:terrain-baseline": "npx tsx scripts/check-terrain-baseline.ts",
    "check:terrain-visual": "npx tsx scripts/check-terrain-visual.ts",
    "check:dropped-frame-ears": "npx tsx scripts/check-dropped-frame-ears.ts",
    "check:visual-integrity": "npx tsx scripts/check-visual-integrity.ts",
    "check:route-quality": "npx tsx scripts/check-route-quality.ts",
    "check:helicopter-parity": "npx tsx scripts/check-helicopter-parity.ts",
    "check:platform-capabilities": "npx tsx scripts/check-platform-capabilities.ts",
    "check:forest-lod-plan": "vitest run src/systems/terrain/ForestAggregateLodPlan.test.ts",
    "check:world-systems-promotion": "vitest run src/systems/world/WorldSystemsPromotionGate.test.ts",
    "check:sky-cloud-post-proof": "npx tsx scripts/check-sky-cloud-post-proof-gate.ts",
    "evidence:atmosphere": "npx tsx scripts/capture-atmosphere-recovery-shots.ts",
    "capture:tod-sweep": "npx tsx scripts/capture-tod-coherence-sweep.ts",
    "check:tod-coherence": "npx tsx scripts/capture-tod-coherence-sweep.ts --gate --label=gate",
    "cloudflare:assets:manifest": "npx tsx scripts/cloudflare-assets.ts manifest",
    "cloudflare:assets:upload": "npx tsx scripts/cloudflare-assets.ts upload",
    "cloudflare:assets:validate": "npx tsx scripts/cloudflare-assets.ts validate",
    "check:states": "npx tsx scripts/state-coverage-probe.ts",
    "profile:modes": "npx tsx scripts/mode-load-profiler.ts",
    "playtest:mobile": "npx tsx scripts/mobile-playtest.ts",
    "playtest:mobile:quick": "npx tsx scripts/mobile-playtest.ts --landscape-only",
    "playtest:mobile:flow": "npx tsx scripts/mobile-playtest.ts --flow-only"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260626.1",
    "@gltf-transform/core": "^4.4.0",
    "@gltf-transform/extensions": "^4.4.0",
    "@types/node": "^26.0.1",
    "@types/three": "^0.184.1",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "bitecs": "^0.4.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^14.0.0",
    "jsdom": "^29.0.1",
    "knip": "^6.4.1",
    "playwright": "^1.59.1",
    "sharp": "^0.35.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.2",
    "wrangler": "^4.84.1"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "flatted": "^3.4.2",
