{
  "name": "terror-in-the-jungle",
  "private": true,
  "version": "0.0.0",
  "knip": {
    "entry": [
      "index.html",
      "public/sw.js",
      "scripts/hud-state-probe.ts",
      "scripts/perf-active-driver.cjs",
      "scripts/perf-browser-observers.js",
      "scripts/probe-alpha-protection.ts",
      "scripts/probe-altitude-hold-clamp.ts",
      "scripts/probe-climb-oscillation.ts",
      "scripts/probe-ground-rolling.ts"
    ],
    "ignoreDependencies": [
      "@cloudflare/workers-types",
      "wrangler"
    ],
    "ignoreFiles": [
      "docs/cycles/**/evidence/**/probe.mts"
    ],
    "ignore": [
      "scripts/capture-*-shots.ts",
      "tools/generate-*.mjs"
    ],
    "ignoreBinaries": [
      "gh"
    ],
    "tags": [
      "-lintignore"
    ]
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "npx tsx scripts/prebake-navmesh.ts",
    "build": "tsc && vite build && npm run cloudflare:assets:manifest",
    "build:perf": "cross-env VITE_PERF_HARNESS=1 tsc && cross-env VITE_PERF_HARNESS=1 vite build --outDir dist-perf && npm run cloudflare:assets:manifest -- --out=dist-perf/asset-manifest.json",
    "typecheck": "tsc --noEmit",
    "doctor": "npx tsx scripts/doctor.ts",
    "validate:fast": "npm run check:pixel-forge-cutover && npm run typecheck && npm run lint && npm run test:quick",
    "navmesh:generate": "npx tsx scripts/prebake-navmesh.ts --force",
    "preview": "vite preview",
    "preview:perf": "vite preview --outDir dist-perf",
    "smoke:prod": "npx tsx scripts/prod-smoke.ts",
    "deploy:prod": "gh workflow run deploy.yml",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "perf:baseline": "npx tsx scripts/perf-baseline.ts",
    "perf:capture": "npx tsx scripts/perf-capture.ts --headed",
    "perf:capture:headless": "npx tsx scripts/perf-capture.ts",
    "perf:capture:headed": "npx tsx scripts/perf-capture.ts --headed",
    "perf:capture:devtools": "npx tsx scripts/perf-capture.ts --headed --devtools",
    "perf:capture:combat120": "npx tsx scripts/perf-capture.ts --headed --mode ai_sandbox --npcs 120 --duration 90 --warmup 15 --seed 2718",
    "perf:capture:zonecontrol": "npx tsx scripts/perf-capture.ts --headed --mode zone_control --npcs 60 --duration 120 --warmup 15 --runtime-preflight false",
    "perf:capture:teamdeathmatch": "npx tsx scripts/perf-capture.ts --headed --mode team_deathmatch --npcs 80 --duration 120 --warmup 15 --runtime-preflight false",
    "perf:capture:openfrontier:short": "npx tsx scripts/perf-capture.ts --headed --mode open_frontier --npcs 120 --duration 180 --warmup 20 --sample-interval-ms 1500 --detail-every-samples 2 --runtime-preflight false",
    "perf:capture:ashau:short": "npx tsx scripts/perf-capture.ts --headed --mode a_shau_valley --npcs 60 --duration 180 --warmup 20 --sample-interval-ms 1500 --detail-every-samples 2 --runtime-preflight false",
    "perf:startup:openfrontier": "npm run build && npx tsx scripts/perf-startup-ui.ts --mode open_frontier",
    "perf:grenade-spike": "npx tsx scripts/perf-grenade-spike.ts --headed --force-build",
    "perf:capture:combat120:losprefilter": "npx tsx scripts/perf-capture.ts --headed --mode ai_sandbox --npcs 120 --duration 90 --warmup 15 --seed 2718 --los-height-prefilter true",
    "perf:capture:frontier30m": "npx tsx scripts/perf-capture.ts --headed --mode open_frontier --npcs 120 --duration 1800 --warmup 30 --sample-interval-ms 2000 --detail-every-samples 5 --runtime-preflight false --match-duration 3600 --disable-victory true",
    "perf:analyze:latest": "npx tsx scripts/perf-analyze-latest.ts",
    "perf:terrain-probe": "npx tsx scripts/terrain-stream-probe.ts",
    "perf:terrain-probe:ashau": "npx tsx scripts/terrain-stream-probe.ts --mode a_shau_valley",
    "perf:terrain-probe:ashau:traverse": "npx tsx scripts/terrain-stream-probe.ts --mode a_shau_valley --samples 10 --interval-ms 750 --settle-ms 2000 --move-step 160",
    "perf:terrain-probe:frontier:traverse": "npx tsx scripts/terrain-stream-probe.ts --mode open_frontier --samples 10 --interval-ms 750 --settle-ms 2000 --move-step 160",
    "assets:optimize": "npx tsx scripts/optimize-assets.ts",
    "assets:optimize:vegetation": "npm run check:pixel-forge-cutover",
    "assets:optimize:dry": "npx tsx scripts/optimize-assets.ts --dry-run",
    "assets:fix-alpha": "npm run check:pixel-forge-cutover",
    "ui:matrix": "npx tsx scripts/ui-device-matrix.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:integration": "vitest run src/integration/",
    "test:frontier": "vitest run src/systems/terrain/TerrainRenderRuntime.test.ts src/systems/terrain/TerrainSystem.test.ts src/systems/player/PlayerMovement.test.ts src/systems/helicopter/HelipadSystem.test.ts src/systems/helicopter/HelicopterModel.test.ts src/integration/scenarios/combat-flow.test.ts src/integration/scenarios/zone-capture.test.ts",
    "test:determinism": "vitest run src/core/SeededRandom.test.ts src/core/ReplayRecorder.test.ts src/core/ReplayPlayer.test.ts",
    "test:quick": "vitest run --reporter=dot",
    "deadcode": "knip",
    "perf:quick": "npx tsx scripts/perf-capture.ts --headed --duration 30 --warmup 8 --npcs 60",
    "perf:compare": "npx tsx scripts/perf-compare.ts",
    "perf:compare:strict": "npx tsx scripts/perf-compare.ts --fail-on-warn",
    "perf:update-baseline": "npx tsx scripts/perf-compare.ts --update-baseline",
    "validate": "npm run lint && npm run test:run && npm run build && npm run smoke:prod",
    "validate:full": "npm run test:run && npm run build && npm run perf:capture:combat120 && npm run perf:compare -- --scenario combat120",
    "probe": "npx tsx scripts/engine-health-probe.ts",
    "probe:pixel-forge-npcs": "npx tsx scripts/probe-pixel-forge-npcs.ts",
    "probe:all": "npx tsx scripts/engine-health-probe.ts --all-modes",
    "probe:fixed-wing": "npx tsx scripts/fixed-wing-runtime-probe.ts",
    "check:hud": "npx tsx scripts/hud-layout-validator.ts",
    "check:mobile-ui": "npx tsx scripts/mobile-ui-check.ts",
    "check:memory": "npx tsx scripts/memory-growth-tracker.ts",
    "check:assets": "npx tsx scripts/asset-load-analyzer.ts",
    "check:pixel-forge-cutover": "npx tsx scripts/validate-pixel-forge-cutover.ts",
    "check:pixel-forge-textures": "npx tsx scripts/pixel-forge-texture-audit.ts",
    "check:pixel-forge-optics": "npx tsx scripts/pixel-forge-imposter-optics-audit.ts",
    "check:vegetation-horizon": "npx tsx scripts/vegetation-horizon-audit.ts",
    "check:webgpu-strategy": "npx tsx scripts/webgpu-strategy-audit.ts",
    "check:projekt-143": "npx tsx scripts/projekt-143-evidence-suite.ts",
    "check:projekt-143-cycle1-bundle": "npx tsx scripts/projekt-143-cycle1-benchmark-bundle.ts",
    "evidence:atmosphere": "npx tsx scripts/capture-atmosphere-recovery-shots.ts",
    "cloudflare:assets:manifest": "npx tsx scripts/cloudflare-assets.ts manifest",
    "cloudflare:assets:upload": "npx tsx scripts/cloudflare-assets.ts upload",
    "cloudflare:assets:validate": "npx tsx scripts/cloudflare-assets.ts validate",
    "check:states": "npx tsx scripts/state-coverage-probe.ts",
    "profile:modes": "npx tsx scripts/mode-load-profiler.ts",
    "playtest:mobile": "npx tsx scripts/mobile-playtest.ts",
    "playtest:mobile:quick": "npx tsx scripts/mobile-playtest.ts --landscape-only",
    "playtest:mobile:flow": "npx tsx scripts/mobile-playtest.ts --flow-only"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260422.1",
    "@types/node": "^25.6.0",
    "@types/three": "^0.184.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "jsdom": "^29.0.1",
    "knip": "^6.4.1",
    "playwright": "^1.59.1",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.2",
    "wrangler": "^4.84.1"
  },
  "overrides": {
    "flatted": "^3.4.2"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource/rajdhani": "^5.2.7",
    "@fontsource/teko": "^5.2.7",
    "@preact/signals-core": "^1.14.1",
    "@recast-navigation/core": "^0.43.0",
    "@recast-navigation/generators": "^0.43.0",
    "@recast-navigation/three": "^0.43.0",
    "@game-field-kits/event-bus": "file:../game-field-kits/packages/event-bus",
    "@game-field-kits/frame-scheduler": "file:../game-field-kits/packages/frame-scheduler",
    "@game-field-kits/three-effect-pool": "file:../game-field-kits/packages/three-effect-pool",
    "@game-field-kits/three-model-optimizer": "file:../game-field-kits/packages/three-model-optimizer",
    "three": "^0.184.0",
    "three-mesh-bvh": "^0.9.9",
    "tweakpane": "^4.0.5"
  }
}

