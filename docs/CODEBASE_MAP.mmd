%%{ init: { 'theme': 'dark', 'themeVariables': { 'fontSize': '12px' } } }%%
graph TD
    subgraph Core["CORE (Engine Shell)"]
        GE[GameEngine]
        GR[GameRenderer]
        SM[SystemManager]
        SI[SystemInitializer]
        SC[SystemConnector]
        SU[SystemUpdater]
    end

    subgraph Combat["COMBAT (5ms budget)"]
        CS[CombatantSystem]
        subgraph CombatInternal[" "]
            AI[CombatantAI + ai/*]
            SGM[SpatialGridManager ★]
            SQM[SquadManager]
            LOD[CombatantLODManager]
            IMS[InfluenceMapSystem]
            PSC[PlayerSquadController]
        end
    end

    subgraph Terrain["TERRAIN (2ms budget)"]
        CM[ImprovedChunkManager]
        subgraph TerrainInternal[" "]
            CWP[ChunkWorkerPool]
            HQC[HeightQueryCache ★]
            DEM[DEMHeightProvider]
        end
    end

    subgraph Strategy["STRATEGY - A Shau (2ms budget)"]
        WS[WarSimulator]
        subgraph StratInternal[" "]
            MP[MaterializationPipeline]
            ACR[AbstractCombatResolver]
            SD[StrategicDirector]
            WEE[WarEventEmitter]
        end
        SF[StrategicFeedback]
    end

    subgraph Player["PLAYER (1ms budget)"]
        PC[PlayerController]
        FPW[FirstPersonWeapon]
        PHS[PlayerHealthSystem]
        PRM[PlayerRespawnManager]
        INV[InventoryManager]
        PSS[PlayerSuppressionSystem]
    end

    subgraph Weapons["WEAPONS (1ms budget)"]
        GS[GrenadeSystem]
        MS[MortarSystem]
        SS[SandbagSystem]
        ASS[AmmoSupplySystem]
    end

    subgraph Vehicle["VEHICLE (deferred)"]
        HM[HelicopterModel]
        HPS[HelipadSystem]
    end

    subgraph World["WORLD (1ms budget)"]
        ZM[ZoneManager]
        TS[TicketSystem]
        GMM[GameModeManager]
    end

    subgraph Billboard["BILLBOARDS (2ms)"]
        GBS[GlobalBillboardSystem]
    end

    subgraph Environment["ENVIRONMENT"]
        WS2[WeatherSystem]
        WTS[WaterSystem]
        SKY[Skybox]
    end

    subgraph Audio["AUDIO"]
        AM[AudioManager]
    end

    subgraph UI["UI"]
        HUD[HUDSystem]
        MMS[MinimapSystem]
        FMS[FullMapSystem]
        CPS[CompassSystem]
    end

    subgraph Effects["EFFECTS"]
        CSH[CameraShakeSystem]
        SMC[SmokeCloudSystem]
    end

    %% --- WIRING: Fan-in >= 5 (heavy dependencies shown) ---

    %% ZoneManager (fan-in 11 - most depended on)
    CS -->|zones| ZM
    TS -->|zones| ZM
    HUD -->|zones| ZM
    MMS -->|zones| ZM
    FMS -->|zones| ZM
    CPS -->|zones| ZM
    FPW -->|zones| ZM
    PHS -->|zones| ZM
    PRM -->|zones| ZM
    ASS -->|zones| ZM
    WS -->|zones| ZM

    %% TicketSystem (fan-in 9)
    CS -->|tickets| TS
    FPW -->|tickets| TS
    GS -->|tickets| TS
    MS -->|tickets| TS
    SS -->|tickets| TS
    PC -->|tickets| TS
    PHS -->|tickets| TS
    WS -->|tickets| TS

    %% CombatantSystem (fan-in 8)
    FPW -->|combat| CS
    GS -->|combat| CS
    MS -->|combat| CS
    HUD -->|combat| CS
    MMS -->|combat| CS
    FMS -->|combat| CS
    WS -->|combat| CS
    ZM -->|spatial query| CS

    %% AudioManager (fan-in 7)
    CS -->|audio| AM
    FPW -->|audio| AM
    GS -->|audio| AM
    MS -->|audio| AM
    HM -->|audio| AM
    SF -->|audio| AM
    WS2 -->|audio| AM

    %% HUDSystem (fan-in 7)
    CS -->|hud| HUD
    FPW -->|hud| HUD
    HM -->|hud| HUD
    PC -->|hud| HUD
    PHS -->|hud| HUD
    SF -->|hud| HUD
    ZM -->|hud| HUD

    %% ChunkManager (fan-in 7)
    CS -->|terrain| CM
    PC -->|terrain| CM
    PRM -->|terrain| CM
    HM -->|terrain| CM
    HPS -->|terrain| CM
    ZM -->|terrain| CM

    %% InventoryManager (fan-in 7)
    FPW -->|inv| INV
    GS -->|inv| INV
    MS -->|inv| INV
    SS -->|inv| INV
    ASS -->|inv| INV
    PC -->|inv| INV
    PRM -->|inv| INV

    %% PlayerController (fan-in 7)
    FPW -->|player| PC
    GS -->|player| PC
    HM -->|player| PC
    PHS -->|player| PC
    PRM -->|player| PC
    PSS -->|player| PC

    %% WarSimulator (fan-in 5)
    SF -->|warsim| WS
    GMM -->|warsim| WS
    MMS -->|warsim| WS
    FMS -->|warsim| WS
    PRM -->|warsim| WS

    %% Strategy internal
    WS --> MP
    WS --> ACR
    WS --> SD
    WS --> WEE
    SF -.->|subscribes| WEE

    %% Materialization bridge
    MP ==>|materialize/dematerialize| CS

    %% Other notable
    PC -->|helicopter| HM
    HM -->|helipads| HPS
    HPS -->|vegetation| GBS
    WTS -->|weather| WS2
    PC -->|camshake| CSH
    PSS -->|camshake| CSH
    GMM -->|influence| IMS

    %% Engine orchestration
    GE --> SM
    GE --> GR
    SM --> SI
    SM --> SC
    SM --> SU

    %% Tick dispatch
    SU ==>|5ms| CS
    SU ==>|2ms| CM
    SU ==>|2ms| GBS
    SU ==>|1ms| PC
    SU ==>|1ms| FPW
    SU ==>|1ms| GS
    SU ==>|1ms| HUD
    SU ==>|2ms| WS
    SU ==>|1ms| ZM

    %% Styling
    classDef singleton fill:#4a1942,stroke:#e91e9c,stroke-width:2px
    classDef deferred fill:#1a3a1a,stroke:#4caf50,stroke-dasharray: 5 5
    classDef hub fill:#1a1a4a,stroke:#5555ff,stroke-width:2px
    classDef disabled fill:#333,stroke:#666,stroke-dasharray: 3 3

    class SGM,HQC singleton
    class HM,HPS deferred
    class ZM,TS,CS,AM,CM hub

    %% ★ = singleton
