/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: credentialless

/build-assets/*
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=0, must-revalidate

/models/*
  Cache-Control: public, max-age=0, must-revalidate

/sw.js
  Cache-Control: public, max-age=0, must-revalidate

# /data/* rules are split into specific subpaths so that Cloudflare Pages does
# not merge multiple matching Cache-Control values into one concatenated header
# (observed in prod before 2026-04-16: "max-age=31536000, immutable, max-age=86400").
# See docs/DEPLOY_WORKFLOW.md section 2 for context.

/data/navmesh/*
  Cache-Control: public, max-age=31536000, immutable

/data/heightmaps/*
  Cache-Control: public, max-age=31536000, immutable

/data/vietnam/*
  Cache-Control: public, max-age=86400

/
  Cache-Control: public, max-age=0, must-revalidate

/index.html
  Cache-Control: public, max-age=0, must-revalidate
